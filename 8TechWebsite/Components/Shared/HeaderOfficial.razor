@implements IComponent
@inject NavigationManager NavigationManager

<header class="header-fixed">
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <a href="/" class="logo-link">
                    <div class="logo-container">
                        <!-- Logo oficial 8Tech com efeito neon -->
                        <img src="/images/8tech-logo-official.png" 
                             alt="8Tech" 
                             class="logo-image"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                        
                        <!-- Fallback com texto estilizado neon -->
                        <div class="logo-text-fallback" style="display: none;">
                            <span class="logo-8">8</span><span class="logo-tech">Tech</span>
                        </div>
                    </div>
                </a>
            </div>
            
            <div class="nav-menu @(mobileMenuOpen ? "active" : "")">
                <ul class="nav-list">
                    <li class="nav-item">
                        <a href="#solucoes" class="nav-link" @onclick="() => CloseMobileMenu()">
                            Soluções
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#servicos" class="nav-link" @onclick="() => CloseMobileMenu()">
                            Serviços
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#sobre" class="nav-link" @onclick="() => CloseMobileMenu()">
                            Sobre
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#contato" class="nav-link" @onclick="() => CloseMobileMenu()">
                            Contato
                        </a>
                    </li>
                </ul>
            </div>
            
            <button class="mobile-menu-toggle" @onclick="ToggleMobileMenu">
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
            </button>
        </div>
    </nav>
</header>

<style>
    .header-fixed {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: rgba(15, 23, 42, 0.95);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--card-border);
        transition: all var(--transition-normal);
    }

    .navbar {
        padding: var(--spacing-sm) 0;
    }

    .navbar .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .nav-brand .logo-link {
        text-decoration: none;
    }

    .logo-container {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .logo-image {
        height: 45px;
        width: auto;
        filter: drop-shadow(var(--shadow-neon-combo));
        transition: all var(--transition-normal);
        animation: logoNeonPulse 3s ease-in-out infinite;
    }

    .logo-image:hover {
        transform: scale(1.05);
        filter: drop-shadow(var(--shadow-neon-hover));
    }

    /* Fallback text com estilo neon */
    .logo-text-fallback {
        display: flex;
        align-items: center;
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .logo-8 {
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: 0 0 20px rgba(147, 51, 234, 0.5);
    }

    .logo-tech {
        background: linear-gradient(90deg, #EC4899 0%, #06B6D4 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: 0 0 20px rgba(236, 72, 153, 0.5);
    }

    .nav-menu {
        display: flex;
        align-items: center;
    }

    .nav-list {
        display: flex;
        list-style: none;
        gap: var(--spacing-lg);
        margin: 0;
        padding: 0;
    }

    .nav-link {
        color: var(--muted-text);
        text-decoration: none;
        font-weight: 500;
        padding: var(--spacing-xs) var(--spacing-sm);
        border-radius: var(--border-radius);
        transition: all var(--transition-fast);
        position: relative;
    }

    .nav-link::before {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 50%;
        width: 0;
        height: 2px;
        background: var(--logo-gradient);
        transform: translateX(-50%);
        transition: width var(--transition-normal);
    }

    .nav-link:hover {
        color: var(--light-text);
        text-shadow: 0 0 10px rgba(236, 72, 153, 0.5);
    }

    .nav-link:hover::before {
        width: 80%;
        box-shadow: 0 0 10px rgba(147, 51, 234, 0.5);
    }

    .mobile-menu-toggle {
        display: none;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: var(--spacing-xs);
    }

    .hamburger-line {
        width: 24px;
        height: 2px;
        background: var(--light-text);
        transition: all var(--transition-normal);
        box-shadow: 0 0 5px rgba(236, 72, 153, 0.5);
    }

    .mobile-menu-toggle.active .hamburger-line:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
        background: var(--neon-pink);
    }

    .mobile-menu-toggle.active .hamburger-line:nth-child(2) {
        opacity: 0;
    }

    .mobile-menu-toggle.active .hamburger-line:nth-child(3) {
        transform: rotate(-45deg) translate(7px, -6px);
        background: var(--neon-cyan);
    }

    /* Mobile Responsivo */
    @@media (max-width: 768px) {
        .mobile-menu-toggle {
            display: flex;
        }

        .nav-menu {
            position: fixed;
            top: 70px;
            left: 0;
            right: 0;
            background: var(--dark-surface);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--card-border);
            transform: translateY(-100%);
            opacity: 0;
            visibility: hidden;
            transition: all var(--transition-normal);
        }

        .nav-menu.active {
            transform: translateY(0);
            opacity: 1;
            visibility: visible;
        }

        .nav-list {
            flex-direction: column;
            padding: var(--spacing-lg);
            gap: var(--spacing-md);
        }

        .nav-link {
            display: block;
            text-align: center;
            padding: var(--spacing-sm);
        }

        .logo-image {
            height: 35px;
        }

        .logo-text-fallback {
            font-size: 1.8rem;
        }
    }

    /* Animações neon */
    @@keyframes logoNeonPulse {
        0%, 100% {
            filter: drop-shadow(0 0 20px rgba(147, 51, 234, 0.6));
        }
        50% {
            filter: drop-shadow(0 0 30px rgba(236, 72, 153, 0.8));
        }
    }

    @@keyframes logoNeonGlow {
        0%, 100% {
            filter: drop-shadow(0 0 25px rgba(147, 51, 234, 0.8));
        }
        50% {
            filter: drop-shadow(0 0 40px rgba(6, 182, 212, 1));
        }
    }
</style>

@code {
    private bool mobileMenuOpen = false;

    private void ToggleMobileMenu()
    {
        mobileMenuOpen = !mobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        mobileMenuOpen = false;
        StateHasChanged();
    }
}
