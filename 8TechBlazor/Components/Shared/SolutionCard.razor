@using Microsoft.JSInterop

@inject IJSRuntime JSRuntime

<div class="solution-card">
    <div class="solution-header">
        <div class="solution-icon-large">@Icon</div>
        <h3 class="solution-title">@Title</h3>
    </div>
    <div class="solution-content">
        <p class="solution-description">@Description</p>
        <div class="solution-features">
            @foreach (var feature in Features)
            {
                <div class="feature-item">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 6L9 17l-5-5"/>
                    </svg>
                    <span>@feature</span>
                </div>
            }
        </div>
    </div>
    <div class="solution-footer">
        <button class="solution-action" @onclick="OnLearnMore">
            Explorar solução
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public string Icon { get; set; } = string.Empty;

    [Parameter]
    public List<string> Features { get; set; } = new();

    private async Task OnLearnMore()
    {
        await JSRuntime.InvokeVoidAsync("scrollToSection", "contact");
    }
}
