<section class="contact-section section-padding" id="contato">
    <div class="container">
        <div class="section-header animate-on-scroll">
            <h2 class="section-title">
                <span class="gradient-text">Fale Conosco</span>
            </h2>
            <p class="section-description">
                Estamos prontos para transformar suas ideias em realidade. 
                Vamos conversar sobre como podemos ajudar seu negócio a crescer.
            </p>
        </div>

        <div class="contact-content">
            <div class="contact-info animate-on-scroll">
                <div class="contact-card">
                    <h3 class="contact-title">Entre em contato</h3>
                    <p class="contact-description">
                        Nossa equipe está disponível para entender suas necessidades 
                        e propor as melhores soluções tecnológicas.
                    </p>
                    
                    <div class="contact-items">
                        <div class="contact-item">
                            <div class="contact-icon">📧</div>
                            <div class="contact-details">
                                <h4>Email</h4>
                                <a href="mailto:contato@8tech.com.br">contato@8tech.com.br</a>
                            </div>
                        </div>
                        
                        <div class="contact-item">
                            <div class="contact-icon">📱</div>
                            <div class="contact-details">
                                <h4>Telefone</h4>
                                <a href="tel:+5511999999999">+55 11 9999-9999</a>
                            </div>
                        </div>
                        
                        <div class="contact-item">
                            <div class="contact-icon">📍</div>
                            <div class="contact-details">
                                <h4>Endereço</h4>
                                <p>São Paulo, SP - Brasil</p>
                            </div>
                        </div>
                        
                        <div class="contact-item">
                            <div class="contact-icon">🕐</div>
                            <div class="contact-details">
                                <h4>Horário</h4>
                                <p>Segunda a Sexta: 9h às 18h</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="social-card">
                    <h4>Siga-nos</h4>
                    <div class="social-links-large">
                        <a href="#" class="social-link-large" aria-label="LinkedIn">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                            </svg>
                        </a>
                        <a href="#" class="social-link-large" aria-label="GitHub">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                            </svg>
                        </a>
                        <a href="#" class="social-link-large" aria-label="Twitter">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <div class="contact-form animate-on-scroll">
                <div class="form-card">
                    <h3 class="form-title">Envie uma mensagem</h3>
                    
                    <EditForm Model="@contactForm" OnValidSubmit="HandleSubmit" class="contact-form">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label for="name">Nome *</label>
                                <InputText id="name" class="form-input" @bind-Value="contactForm.Name" />
                                <ValidationMessage For="@(() => contactForm.Name)" />
                            </div>
                            
                            <div class="form-group">
                                <label for="email">Email *</label>
                                <InputText id="email" class="form-input" @bind-Value="contactForm.Email" />
                                <ValidationMessage For="@(() => contactForm.Email)" />
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label for="company">Empresa</label>
                            <InputText id="company" class="form-input" @bind-Value="contactForm.Company" />
                        </div>
                        
                        <div class="form-group">
                            <label for="service">Serviço de Interesse</label>
                            <InputSelect id="service" class="form-input" @bind-Value="contactForm.Service">
                                <option value="">Selecione um serviço</option>
                                <option value="ia">Inteligência Artificial</option>
                                <option value="cloud">Computação em Nuvem</option>
                                <option value="dados">Análise de Dados</option>
                                <option value="consultoria">Consultoria</option>
                                <option value="outro">Outro</option>
                            </InputSelect>
                        </div>
                        
                        <div class="form-group">
                            <label for="message">Mensagem *</label>
                            <InputTextArea id="message" class="form-input" @bind-Value="contactForm.Message" rows="5" />
                            <ValidationMessage For="@(() => contactForm.Message)" />
                        </div>
                        
                        <button type="submit" class="btn-primary btn-large" disabled="@isSubmitting">
                            @(isSubmitting ? "Enviando..." : "Enviar mensagem")
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
                            </svg>
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .contact-section {
        background: linear-gradient(135deg, var(--dark-surface) 0%, var(--dark-bg) 100%);
    }

    .contact-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-2xl);
    }

    .contact-card, .form-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--border-radius);
        padding: var(--spacing-2xl);
        backdrop-filter: blur(10px);
        height: fit-content;
    }

    .contact-title, .form-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--light-text);
        margin: 0 0 var(--spacing-md) 0;
    }

    .contact-description {
        color: var(--muted-text);
        line-height: 1.6;
        margin-bottom: var(--spacing-xl);
    }

    .contact-items {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-lg);
    }

    .contact-item {
        display: flex;
        gap: var(--spacing-md);
        align-items: start;
    }

    .contact-icon {
        font-size: 1.5rem;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(147, 51, 234, 0.1);
        border: 1px solid rgba(147, 51, 234, 0.2);
        border-radius: var(--border-radius);
        flex-shrink: 0;
    }

    .contact-details h4 {
        color: var(--light-text);
        font-size: 1rem;
        font-weight: 600;
        margin: 0 0 var(--spacing-xs) 0;
    }

    .contact-details a,
    .contact-details p {
        color: var(--muted-text);
        text-decoration: none;
        transition: color var(--transition-fast);
    }

    .contact-details a:hover {
        color: var(--accent-color);
    }

    .social-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--border-radius);
        padding: var(--spacing-lg);
        backdrop-filter: blur(10px);
        margin-top: var(--spacing-lg);
    }

    .social-card h4 {
        color: var(--light-text);
        font-weight: 600;
        margin: 0 0 var(--spacing-md) 0;
    }

    .social-links-large {
        display: flex;
        gap: var(--spacing-md);
    }

    .social-link-large {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        background: rgba(147, 51, 234, 0.1);
        border: 1px solid rgba(147, 51, 234, 0.2);
        border-radius: 50%;
        color: var(--muted-text);
        text-decoration: none;
        transition: all var(--transition-normal);
    }

    .social-link-large:hover {
        background: var(--logo-gradient);
        border-color: transparent;
        color: white;
        transform: translateY(-2px);
        box-shadow: var(--shadow-neon-combo);
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-lg);
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-md);
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-xs);
    }

    .form-group label {
        color: var(--light-text);
        font-weight: 500;
        font-size: 0.9rem;
    }

    .form-input {
        background: var(--dark-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--border-radius);
        padding: var(--spacing-sm);
        color: var(--light-text);
        font-family: var(--font-family);
        transition: all var(--transition-fast);
    }

    .form-input:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 0 3px rgba(147, 51, 234, 0.1);
    }

    /* Mobile Responsivo */
    @@media (max-width: 768px) {
        .contact-content {
            grid-template-columns: 1fr;
            gap: var(--spacing-xl);
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .contact-card, .form-card {
            padding: var(--spacing-xl);
        }
    }
</style>

@code {
    private ContactFormModel contactForm = new();
    private bool isSubmitting = false;
    private string? submitMessage;

    public class ContactFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Company { get; set; } = string.Empty;
        public string Service { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        
        try
        {
            // Simular envio do formulário
            await Task.Delay(2000);
            
            submitMessage = "Mensagem enviada com sucesso! Entraremos em contato em breve.";
            contactForm = new(); // Limpar formulário
        }
        catch (Exception ex)
        {
            submitMessage = "Erro ao enviar mensagem. Tente novamente.";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }
}
